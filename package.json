{
  "name": "@islam_gagiev_101/jet-ui",
  "version": "0.2.7",
  "description": "Stimulus controllers for JetRockets jet_ui Rails components",
  "license": "MIT",
  "type": "module",
  "main": "dist/jet-ui.umd.cjs",
  "module": "src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./dist/jet-ui.umd.cjs"
    },
    "./css": "./app/assets/stylesheets/jet_ui.css",
    "./css/*": "./app/assets/stylesheets/jet_ui/*"
  },
  "files": [
    "dist",
    "src",
    "app/assets/javascripts",
    "app/assets/stylesheets"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "prepare": "vite build"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@hotwired/stimulus": "^3.0"
  },
  "devDependencies": {
    "vite": "^6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jetrockets/jet_ui"
  },
  "homepage": "https://ui.jetrockets.com",
  "keywords": [
    "stimulus",
    "stimulusjs",
    "rails",
    "jet_ui",
    "jetrockets",
    "viewcomponent"
  ]
}
