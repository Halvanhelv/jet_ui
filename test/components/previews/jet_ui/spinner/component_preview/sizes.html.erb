<div class="flex items-end gap-4 p-4">
  <% [4, 5, 6, 8, 10, 12].each do |size| %>
    <div class="flex flex-col items-center gap-1">
      <%= render JetUi::Spinner::Component.new(size: size) %>
      <span class="text-xs text-muted-foreground">size-<%= size %></span>
    </div>
  <% end %>
</div>
