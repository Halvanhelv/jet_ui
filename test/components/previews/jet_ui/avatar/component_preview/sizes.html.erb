<div class="flex items-end gap-4 p-4">
  <% [6, 8, 10, 12, 16, 20].each do |size| %>
    <div class="flex flex-col items-center gap-1">
      <%= render JetUi::Avatar::Component.new(name: 'John Doe', size: size) %>
      <span class="text-xs text-muted-foreground">size-<%= size %></span>
    </div>
  <% end %>
</div>
